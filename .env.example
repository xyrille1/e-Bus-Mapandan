# Copy this file to .env and fill in your credentials.
# EXPO_PUBLIC_* variables are bundled into the client app — only safe public keys go here.

# ─── Supabase ────────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️  SERVER-SIDE ONLY — never use EXPO_PUBLIC_ prefix for this key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Push Notifications ───────────────────────────────────────────────────────
# expo.dev → project → Push Notifications
EXPO_ACCESS_TOKEN=

# ─── App Config ───────────────────────────────────────────────────────────────
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_LIVE_TICK_MS=5000
EXPO_PUBLIC_DEAD_RECKONING_THRESHOLD_MINS=3
